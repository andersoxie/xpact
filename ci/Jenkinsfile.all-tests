def xmlEscape(value) {
  if (value == null) {
    return ''
  }
  return value.toString()
    .replace('&', '&amp;')
    .replace('<', '&lt;')
    .replace('>', '&gt;')
    .replace('"', '&quot;')
    .replace("'", '&apos;')
}

def safeReportToken(value) {
  def token = value.toString().replaceAll(/[^A-Za-z0-9_.-]+/, '-')
  token = token.replaceAll(/^-+/, '').replaceAll(/-+$/, '')
  if (token.length() == 0) {
    return 'report'
  }
  if (token.length() > 120) {
    return token.substring(0, 120)
  }
  return token
}

def formatSeconds(value) {
  return String.format(java.util.Locale.US, '%.3f', value as double)
}

def writeSingleCaseJUnitReport(suiteName, caseName, elapsedSeconds, failureMessage, failureText) {
  def failures = failureText == null ? 0 : 1
  def failureXml = ''
  if (failureText != null) {
    failureXml = "\n    <failure message=\"${xmlEscape(failureMessage)}\">${xmlEscape(failureText)}</failure>\n  "
  }
  writeFile file: "jenkins-test-results-${safeReportToken(suiteName)}-${safeReportToken(caseName)}.xml",
            text: """<?xml version="1.0" encoding="UTF-8"?>
<testsuite name="${xmlEscape(suiteName)}" tests="1" failures="${failures}" skipped="0" time="${formatSeconds(elapsedSeconds)}">
  <testcase classname="${xmlEscape(suiteName)}" name="${xmlEscape(caseName)}" time="${formatSeconds(elapsedSeconds)}">${failureXml}</testcase>
</testsuite>
"""
}

def runWithJenkinsTestResult(suiteName, caseName, Closure body) {
  def started = System.currentTimeMillis()
  def failureMessage = null
  def failureText = null
  try {
    body()
  } catch (Throwable err) {
    failureMessage = err.getMessage()
    failureText = err.toString()
    throw err
  } finally {
    def elapsedSeconds = (System.currentTimeMillis() - started) / 1000.0
    writeSingleCaseJUnitReport(suiteName, caseName, elapsedSeconds, failureMessage, failureText)
  }
}

def parseTsvLine(line) {
  return line.split('\t', -1).collect { cell ->
    def value = cell
    if (value.length() >= 2 && value.startsWith('"') && value.endsWith('"')) {
      value = value.substring(1, value.length() - 1).replace('""', '"')
    }
    value
  }
}

def writeBenchmarkJUnitReport(tsvPath, suiteName, reportName) {
  if (!fileExists(tsvPath)) {
    return
  }
  def text = readFile(tsvPath).replaceFirst(/^\uFEFF/, '')
  def lines = text.split(/\r?\n/).findAll { it.trim().length() > 0 }
  if (lines.size() < 2) {
    return
  }

  def headers = parseTsvLine(lines[0]).collect { it.replaceFirst(/^\uFEFF/, '') }
  def cases = new StringBuilder()
  def count = 0
  lines.drop(1).each { line ->
    def values = parseTsvLine(line)
    def row = [:]
    headers.eachWithIndex { header, index ->
      row[header] = index < values.size() ? values[index] : ''
    }
    count += 1

    def elapsedMs = parseNumericValue(row['ElapsedMs'])
    def elapsedSeconds = elapsedMs == null ? '0.000' : formatSeconds(elapsedMs / 1000.0)

    def primaryName = row['Benchmark'] ?: row['CorpusId'] ?: "row-${count}"
    def engineName = row['Engine'] ?: 'engine'
    def repetition = row['Repetition'] ?: count.toString()
    def caseName = "${primaryName} / ${engineName} / rep ${repetition}"
    def properties = new StringBuilder()
    headers.each { header ->
      properties.append("      <property name=\"${xmlEscape(header)}\" value=\"${xmlEscape(row[header])}\"/>\n")
    }
    cases.append("""  <testcase classname="${xmlEscape(suiteName)}" name="${xmlEscape(caseName)}" time="${elapsedSeconds}">
    <properties>
${properties}    </properties>
  </testcase>
""")
  }

  writeFile file: "jenkins-test-results-${safeReportToken(reportName)}.xml",
            text: """<?xml version="1.0" encoding="UTF-8"?>
<testsuite name="${xmlEscape(suiteName)}" tests="${count}" failures="0" skipped="0">
${cases}</testsuite>
"""
}

def csvEscape(value) {
  def text = value == null ? '' : value.toString()
  if (text.contains('"') || text.contains(',') || text.contains('\n') || text.contains('\r')) {
    return '"' + text.replace('"', '""') + '"'
  }
  return text
}

def parseNumericValue(value) {
  try {
    def text = value == null ? '' : value.toString().trim()
    if (text.length() == 0) {
      return null
    }
    if (text.contains(',') && !text.contains('.')) {
      text = text.replace(',', '.')
    }
    return Double.parseDouble(text)
  } catch (Throwable ignored) {
    return null
  }
}

def medianNumeric(values) {
  if (values == null || values.isEmpty()) {
    return null
  }
  def sorted = values.collect { it as double }.sort()
  return sorted[(int) Math.floor((sorted.size() - 1) / 2)]
}

def writeBenchmarkPlotCsvFiles(tsvPath, reportPrefix, groupName) {
  if (!fileExists(tsvPath)) {
    return []
  }
  def text = readFile(tsvPath).replaceFirst(/^\uFEFF/, '')
  def lines = text.split(/\r?\n/).findAll { it.trim().length() > 0 }
  if (lines.size() < 2) {
    return []
  }

  def headers = parseTsvLine(lines[0]).collect { it.replaceFirst(/^\uFEFF/, '') }
  def byTest = [:]
  lines.drop(1).each { line ->
    def values = parseTsvLine(line)
    def row = [:]
    headers.eachWithIndex { header, index ->
      row[header] = index < values.size() ? values[index] : ''
    }

    def testName = row['Benchmark'] ?: row['CorpusId']
    def engineName = row['Engine']
    def elapsedMs = parseNumericValue(row['ElapsedMs'])
    if (testName && engineName && elapsedMs != null) {
      if (!byTest.containsKey(testName)) {
        byTest[testName] = [:]
      }
      if (!byTest[testName].containsKey(engineName)) {
        byTest[testName][engineName] = []
      }
      byTest[testName][engineName] << elapsedMs
    }
  }

  def plots = []
  def outputDir = tsvPath.contains('/') ? tsvPath.substring(0, tsvPath.lastIndexOf('/')) : '.'
  byTest.keySet().toList().sort().each { testName ->
    def engineNames = byTest[testName].keySet().toList().sort()
    def medians = engineNames.collect { engineName -> medianNumeric(byTest[testName][engineName]) }
    if (medians.any { it != null }) {
      def token = safeReportToken(testName)
      def sourceFile = "${outputDir}/jenkins-plot-${safeReportToken(reportPrefix)}-${token}-elapsed-ms.csv"
      def header = engineNames.collect { csvEscape(it) }.join(',')
      def values = medians.collect { it == null ? '' : String.format(java.util.Locale.US, '%.3f', it as double) }.join(',')
      writeFile file: sourceFile, text: "${header}\n${values}\n"
      plots << [
        sourceFile: sourceFile,
        csvFileName: "plot-${safeReportToken(reportPrefix)}-${token}-elapsed-ms.csv",
        group: groupName,
        title: "${testName} median elapsed time",
        yaxis: 'Median elapsed ms'
      ]
    }
  }
  return plots
}

def publishBenchmarkPlots(plots) {
  plots.each { spec ->
    try {
      plot csvFileName: spec.csvFileName,
           csvSeries: [[file: spec.sourceFile,
                        exclusionValues: '',
                        displayTableFlag: false,
                        inclusionFlag: 'OFF',
                        url: '']],
           group: spec.group,
           title: spec.title,
           style: 'line',
           exclZero: false,
           keepRecords: false,
           logarithmic: false,
           numBuilds: '',
           useDescr: false,
           yaxis: spec.yaxis,
           yaxisMaximum: '',
           yaxisMinimum: ''
    } catch (Throwable err) {
      echo "Benchmark plot '${spec.title}' was not published: ${err.getMessage()}"
    }
  }
}

def publishJenkinsTestResults() {
  junit testResults: 'jenkins-test-results-*.xml',
        allowEmptyResults: true
  powershell returnStatus: true, script: '''
    Get-ChildItem -LiteralPath . -Filter 'jenkins-test-results-*.xml' -File -ErrorAction SilentlyContinue |
      Remove-Item -Force
  '''
}

pipeline {
  agent none

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '30'))
  }

  parameters {
    string(name: 'EXPAT_SOURCE_DIR',
           defaultValue: 'C:\\src\\libexpat-R_2_8_1\\expat',
           description: 'Path to the upstream Expat source tree. libexpat adapter stages are marked unstable when this path does not exist.')
    booleanParam(name: 'RUN_WSL_TESTS',
                 defaultValue: true,
                 description: 'Run WSL/Linux bridge and ABI smoke tests when WSL2 is available.')
    booleanParam(name: 'RUN_LIBEXPAT_NATIVE_SUITE',
                 defaultValue: true,
                 description: 'Build and run upstream libexpat runtests through the xpact adapter.')
    booleanParam(name: 'RUN_CONTRIBUTED_EXAMPLES',
                 defaultValue: true,
                 description: 'Build and run contributed xpact incremental examples.')
    booleanParam(name: 'RUN_BENCHMARKS',
                 defaultValue: false,
                 description: 'Run same-machine benchmark publication.')
    booleanParam(name: 'RUN_LARGE_XML_BENCHMARKS',
                 defaultValue: false,
                 description: 'Run opt-in large XML benchmark publication.')
    string(name: 'LARGE_XML_FILE',
           defaultValue: '',
           description: 'Pre-decompressed XML file for the large XML benchmark.')
    booleanParam(name: 'RUN_SONARQUBE',
                 defaultValue: true,
                 description: 'Run SonarQube analysis using the Jenkins Sonar configuration.')
    booleanParam(name: 'SONARQUBE_REQUIRED',
                 defaultValue: false,
                 description: 'Fail the pipeline when SonarQube analysis fails. When false, SonarQube failures mark the build unstable and later stages can continue.')
  }

  environment {
    ADAPTER_OUTPUT = 'build\\libexpat-adapter-current'
    XPACT_LIBRARY = 'build\\native-eiffel\\xpact.lib'
  }

  stages {
    stage('Checkout') {
      agent { label 'built-in' }
      steps {
        checkout scm
        stash name: 'xpact-source',
              includes: '**/*',
              excludes: 'EIFGENs/**,build/**,dist/**,.git/**'
      }
    }

    stage('Tool Versions') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          . .\\scripts\\import_msvc_environment.ps1
          ec -version
          cl
          cmake --version
          python --version
        '''
      }
    }

    stage('SonarQube analysis') {
      when { expression { return params.RUN_SONARQUBE } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          def runSonarScanner = {
            def scannerHome = tool 'Sonar'
            withSonarQubeEnv() {
              withEnv(["SONAR_SCANNER_HOME=${scannerHome}"]) {
                powershell '''
                  $ErrorActionPreference = "Stop"
                  Set-Location $env:WORKSPACE
                  if (-not (Test-Path sonar-project.properties)) {
                    throw "sonar-project.properties was not found."
                  }
                  Select-String -Path sonar-project.properties -Pattern '^sonar\.projectKey='
                  & "$env:SONAR_SCANNER_HOME\bin\sonar-scanner.bat"
                  if ($LASTEXITCODE -ne 0) { throw "SonarQube analysis failed with exit code $LASTEXITCODE" }
                '''
              }
            }
          }

          if (params.SONARQUBE_REQUIRED) {
            runSonarScanner()
          } else {
            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
              runSonarScanner()
            }
          }
        }
      }
    }

    stage('Eiffel Regression Matrix') {
      matrix {
        axes {
          axis {
            name 'ASSERTIONS'
            values 'Off', 'On'
          }
          axis {
            name 'BUILD_MODE'
            values 'Workbench', 'Finalized'
          }
        }
        agent { label 'built-in' }
        stages {
          stage('Run') {
            steps {
              deleteDir()
              unstash 'xpact-source'
              script {
                runWithJenkinsTestResult('xpact Eiffel regression matrix',
                                         "assertions ${env.ASSERTIONS} / ${env.BUILD_MODE}") {
                  powershell '''
                    $ErrorActionPreference = "Stop"
                    .\\scripts\\run_eiffel_test_matrix.ps1 `
                      -AssertionMode "${env:ASSERTIONS}" `
                      -BuildMode "${env:BUILD_MODE}"
                  '''
                }
              }
            }
            post {
              always {
                script {
                  publishJenkinsTestResults()
                }
              }
            }
          }
        }
      }
    }

    stage('Windows Native Tests') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          runWithJenkinsTestResult('xpact Windows native tests', 'build Eiffel-backed DLLs') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\build_native_eiffel.ps1
              .\\scripts\\build_native_eiffel.ps1 -BuildTier Assertions -SkipSmoke
            '''
          }
          runWithJenkinsTestResult('xpact Windows native tests', 'runtime smoke') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_native_runtime_smoke.ps1
            '''
          }
          runWithJenkinsTestResult('xpact Windows native tests', 'Windows ABI smoke') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_native_abi_tests.ps1 -Target Windows
            '''
          }
          runWithJenkinsTestResult('xpact Windows native tests', 'chunked CRC corpus') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_chunked_crc_corpus.ps1 -Target Xpact -ParseMode All -SkipBuild
            '''
          }
          runWithJenkinsTestResult('xpact Windows native tests', 'incremental shim audit') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_incremental_shim_audit.ps1 -SkipBuild
            '''
          }
        }
      }
      post {
        always {
          script {
            publishJenkinsTestResults()
          }
          archiveArtifacts artifacts: '''
            build/native-eiffel/xpact.dll,
            build/native-eiffel/xpact.lib,
            build/native-eiffel/xpact_assertions.dll,
            build/native-eiffel/xpact_assertions.lib,
            build/native-runtime/*.obj,
            build/chunked-crc/*.tsv,
            build/incremental-shim-audit/*.tsv
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('WSL ABI Tests') {
      when { expression { return params.RUN_WSL_TESTS } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          runWithJenkinsTestResult('xpact WSL ABI tests', 'WSL ABI smoke') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_native_abi_tests.ps1 -Target Wsl
            '''
          }
        }
      }
      post {
        always {
          script {
            publishJenkinsTestResults()
          }
          archiveArtifacts artifacts: 'build/native/libxpact.so', allowEmptyArchive: true
        }
      }
    }

    stage('libexpat Adapter') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          if (powershell(returnStatus: true, script: '''
            if (Test-Path -LiteralPath "${env:EXPAT_SOURCE_DIR}" -PathType Container) { exit 0 }
            exit 1
          ''') != 0) {
            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
              runWithJenkinsTestResult('libexpat adapter', 'source tree available') {
                error "Skipping libexpat adapter: EXPAT_SOURCE_DIR does not exist: ${env.EXPAT_SOURCE_DIR}"
              }
            }
          } else {
            runWithJenkinsTestResult('libexpat adapter', 'manifest and parity expansion') {
              powershell '''
                $ErrorActionPreference = "Stop"
                .\\scripts\\build_native_eiffel.ps1 -SkipSmoke
                .\\scripts\\run_libexpat_adapter.ps1 `
                  -Mode Manifest `
                  -ExpatSourceDir "${env:EXPAT_SOURCE_DIR}" `
                  -OutputDir "${env:ADAPTER_OUTPUT}" `
                  -XpactLibrary "${env:XPACT_LIBRARY}" `
                  -SkipNativeBuild
              '''
            }
            if (params.RUN_LIBEXPAT_NATIVE_SUITE) {
              runWithJenkinsTestResult('libexpat adapter', 'native suite expected-failure gate') {
                powershell '''
                  $ErrorActionPreference = "Stop"
                  .\\scripts\\run_libexpat_adapter.ps1 `
                    -Mode NativeSuite `
                    -ExpatSourceDir "${env:EXPAT_SOURCE_DIR}" `
                    -OutputDir "${env:ADAPTER_OUTPUT}" `
                    -XpactLibrary "${env:XPACT_LIBRARY}" `
                    -SkipNativeBuild
                '''
              }
            }
          }
        }
      }
      post {
        always {
          script {
            publishJenkinsTestResults()
          }
          archiveArtifacts artifacts: '''
            build/libexpat-adapter-current/*.tsv,
            build/libexpat-adapter-current/*.log
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('Contributed Examples') {
      when { expression { return params.RUN_CONTRIBUTED_EXAMPLES } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          runWithJenkinsTestResult('xpact contributed examples', 'incremental examples') {
            powershell '''
              $ErrorActionPreference = "Stop"
              $runWslExpatComparison = "${env:RUN_WSL_TESTS}" -eq "true"
              .\\scripts\\run_contributed_examples.ps1 `
                -RunWslExpatComparison:$runWslExpatComparison
            '''
          }
        }
      }
      post {
        always {
          script {
            publishJenkinsTestResults()
          }
          archiveArtifacts artifacts: 'build/contributed-examples/*.log', allowEmptyArchive: true
        }
      }
    }

    stage('Benchmarks') {
      when { expression { return params.RUN_BENCHMARKS } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          runWithJenkinsTestResult('xpact benchmarks', 'same-machine benchmark publication') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_benchmarks.ps1 -EiffelBuild Finalized,FinalizedAssertions
            '''
          }
        }
      }
      post {
        always {
          script {
            writeBenchmarkJUnitReport('build/benchmarks/benchmark-results.tsv',
                                      'xpact same-machine benchmark rows',
                                      'same-machine-benchmarks')
            publishBenchmarkPlots(writeBenchmarkPlotCsvFiles('build/benchmarks/benchmark-results.tsv',
                                                             'same-machine-benchmarks',
                                                             'xpact same-machine benchmarks'))
            publishJenkinsTestResults()
          }
          archiveArtifacts artifacts: '''
            build/benchmarks/*.tsv,
            build/benchmarks/*.csv,
            docs/benchmarks.md,
            docs/performance-analysis.md
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('Large XML Benchmarks') {
      when { expression { return params.RUN_LARGE_XML_BENCHMARKS && params.LARGE_XML_FILE?.trim() } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          runWithJenkinsTestResult('xpact large XML benchmarks', 'large XML benchmark publication') {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\run_large_xml_benchmarks.ps1 `
                -XmlFile "${env:LARGE_XML_FILE}" `
                -MaxFileBytes 536870912
            '''
          }
        }
      }
      post {
        always {
          script {
            writeBenchmarkJUnitReport('build/large-xml-benchmarks/large-xml-benchmark-results.tsv',
                                      'xpact large XML benchmark rows',
                                      'large-xml-benchmarks')
            publishBenchmarkPlots(writeBenchmarkPlotCsvFiles('build/large-xml-benchmarks/large-xml-benchmark-results.tsv',
                                                             'large-xml-benchmarks',
                                                             'xpact large XML benchmarks'))
            publishJenkinsTestResults()
          }
          archiveArtifacts artifacts: '''
            build/large-xml-benchmarks/*.tsv,
            build/large-xml-benchmarks/*.csv,
            docs/large-xml-benchmarks.md
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('Package Windows Release') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          .\\scripts\\package_windows_release.ps1
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: 'dist/*.zip,dist/*.txt', allowEmptyArchive: true
        }
      }
    }
  }
}
