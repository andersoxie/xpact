pipeline {
  agent none

  options {
    timestamps()
    buildDiscarder(logRotator(numToKeepStr: '30'))
  }

  parameters {
    string(name: 'EXPAT_SOURCE_DIR',
           defaultValue: 'C:\\src\\libexpat-R_2_8_1\\expat',
           description: 'Path to the upstream Expat source tree. libexpat adapter stages are marked unstable when this path does not exist.')
    booleanParam(name: 'RUN_WSL_TESTS',
                 defaultValue: true,
                 description: 'Run WSL/Linux bridge and ABI smoke tests when WSL2 is available.')
    booleanParam(name: 'RUN_LIBEXPAT_NATIVE_SUITE',
                 defaultValue: true,
                 description: 'Build and run upstream libexpat runtests through the xpact adapter.')
    booleanParam(name: 'RUN_CONTRIBUTED_EXAMPLES',
                 defaultValue: true,
                 description: 'Build and run contributed xpact incremental examples.')
    booleanParam(name: 'RUN_BENCHMARKS',
                 defaultValue: false,
                 description: 'Run same-machine benchmark publication.')
    booleanParam(name: 'RUN_LARGE_XML_BENCHMARKS',
                 defaultValue: false,
                 description: 'Run opt-in large XML benchmark publication.')
    string(name: 'LARGE_XML_FILE',
           defaultValue: '',
           description: 'Pre-decompressed XML file for the large XML benchmark.')
    booleanParam(name: 'RUN_SONARQUBE',
                 defaultValue: true,
                 description: 'Run SonarQube analysis using the Jenkins Sonar configuration.')
    booleanParam(name: 'SONARQUBE_REQUIRED',
                 defaultValue: false,
                 description: 'Fail the pipeline when SonarQube analysis fails. When false, SonarQube failures mark the build unstable and later stages can continue.')
  }

  environment {
    ADAPTER_OUTPUT = 'build\\libexpat-adapter-current'
    XPACT_LIBRARY = 'build\\native-eiffel\\xpact.lib'
  }

  stages {
    stage('Checkout') {
      agent { label 'built-in' }
      steps {
        checkout scm
        stash name: 'xpact-source',
              includes: '**/*',
              excludes: 'EIFGENs/**,build/**,dist/**,.git/**'
      }
    }

    stage('Tool Versions') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          . .\\scripts\\import_msvc_environment.ps1
          ec -version
          cl
          cmake --version
          python --version
        '''
      }
    }

    stage('SonarQube analysis') {
      when { expression { return params.RUN_SONARQUBE } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          def runSonarScanner = {
            def scannerHome = tool 'Sonar'
            withSonarQubeEnv() {
              withEnv(["SONAR_SCANNER_HOME=${scannerHome}"]) {
                powershell '''
                  $ErrorActionPreference = "Stop"
                  Set-Location $env:WORKSPACE
                  if (-not (Test-Path sonar-project.properties)) {
                    throw "sonar-project.properties was not found."
                  }
                  Select-String -Path sonar-project.properties -Pattern '^sonar\.projectKey='
                  & "$env:SONAR_SCANNER_HOME\bin\sonar-scanner.bat"
                  if ($LASTEXITCODE -ne 0) { throw "SonarQube analysis failed with exit code $LASTEXITCODE" }
                '''
              }
            }
          }

          if (params.SONARQUBE_REQUIRED) {
            runSonarScanner()
          } else {
            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
              runSonarScanner()
            }
          }
        }
      }
    }

    stage('Eiffel Regression Matrix') {
      matrix {
        axes {
          axis {
            name 'ASSERTIONS'
            values 'Off', 'On'
          }
          axis {
            name 'BUILD_MODE'
            values 'Workbench', 'Finalized'
          }
        }
        agent { label 'built-in' }
        stages {
          stage('Run') {
            steps {
              deleteDir()
              unstash 'xpact-source'
              powershell '''
                $ErrorActionPreference = "Stop"
                .\\scripts\\run_eiffel_test_matrix.ps1 `
                  -AssertionMode "${env:ASSERTIONS}" `
                  -BuildMode "${env:BUILD_MODE}"
              '''
            }
          }
        }
      }
    }

    stage('Windows Native Tests') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          .\\scripts\\build_native_eiffel.ps1
          .\\scripts\\build_native_eiffel.ps1 -BuildTier Assertions -SkipSmoke
          .\\scripts\\run_native_runtime_smoke.ps1
          .\\scripts\\run_native_abi_tests.ps1 -Target Windows
          .\\scripts\\run_chunked_crc_corpus.ps1 -Target Xpact -ParseMode All -SkipBuild
          .\\scripts\\run_incremental_shim_audit.ps1 -SkipBuild
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: '''
            build/native-eiffel/xpact.dll,
            build/native-eiffel/xpact.lib,
            build/native-eiffel/xpact_assertions.dll,
            build/native-eiffel/xpact_assertions.lib,
            build/native-runtime/*.obj,
            build/chunked-crc/*.tsv,
            build/incremental-shim-audit/*.tsv
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('WSL ABI Tests') {
      when { expression { return params.RUN_WSL_TESTS } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          .\\scripts\\run_native_abi_tests.ps1 -Target Wsl
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: 'build/native/libxpact.so', allowEmptyArchive: true
        }
      }
    }

    stage('libexpat Adapter') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        script {
          if (powershell(returnStatus: true, script: '''
            if (Test-Path -LiteralPath "${env:EXPAT_SOURCE_DIR}" -PathType Container) { exit 0 }
            exit 1
          ''') != 0) {
            catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
              error "Skipping libexpat adapter: EXPAT_SOURCE_DIR does not exist: ${env.EXPAT_SOURCE_DIR}"
            }
          } else {
            powershell '''
              $ErrorActionPreference = "Stop"
              .\\scripts\\build_native_eiffel.ps1 -SkipSmoke
              .\\scripts\\run_libexpat_adapter.ps1 `
                -Mode Manifest `
                -ExpatSourceDir "${env:EXPAT_SOURCE_DIR}" `
                -OutputDir "${env:ADAPTER_OUTPUT}" `
                -XpactLibrary "${env:XPACT_LIBRARY}" `
                -SkipNativeBuild
              if (${env:RUN_LIBEXPAT_NATIVE_SUITE} -eq "true") {
                .\\scripts\\run_libexpat_adapter.ps1 `
                  -Mode NativeSuite `
                  -ExpatSourceDir "${env:EXPAT_SOURCE_DIR}" `
                  -OutputDir "${env:ADAPTER_OUTPUT}" `
                  -XpactLibrary "${env:XPACT_LIBRARY}" `
                  -SkipNativeBuild
              }
            '''
          }
        }
      }
      post {
        always {
          archiveArtifacts artifacts: '''
            build/libexpat-adapter-current/*.tsv,
            build/libexpat-adapter-current/*.log
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('Contributed Examples') {
      when { expression { return params.RUN_CONTRIBUTED_EXAMPLES } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          $runWslExpatComparison = "${env:RUN_WSL_TESTS}" -eq "true"
          .\\scripts\\run_contributed_examples.ps1 `
            -RunWslExpatComparison:$runWslExpatComparison
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: 'build/contributed-examples/*.log', allowEmptyArchive: true
        }
      }
    }

    stage('Benchmarks') {
      when { expression { return params.RUN_BENCHMARKS } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          .\\scripts\\run_benchmarks.ps1 -EiffelBuild Finalized,FinalizedAssertions
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: '''
            build/benchmarks/*.tsv,
            docs/benchmarks.md,
            docs/performance-analysis.md
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('Large XML Benchmarks') {
      when { expression { return params.RUN_LARGE_XML_BENCHMARKS && params.LARGE_XML_FILE?.trim() } }
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          .\\scripts\\run_large_xml_benchmarks.ps1 `
            -XmlFile "${env:LARGE_XML_FILE}" `
            -MaxFileBytes 536870912
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: '''
            build/large-xml-benchmarks/*.tsv,
            docs/large-xml-benchmarks.md
          ''', allowEmptyArchive: true
        }
      }
    }

    stage('Package Windows Release') {
      agent { label 'built-in' }
      steps {
        deleteDir()
        unstash 'xpact-source'
        powershell '''
          $ErrorActionPreference = "Stop"
          .\\scripts\\package_windows_release.ps1
        '''
      }
      post {
        always {
          archiveArtifacts artifacts: 'dist/*.zip,dist/*.txt', allowEmptyArchive: true
        }
      }
    }
  }
}
